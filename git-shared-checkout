#!/bin/bash -eu

#
# This is a utility to checkout git repositories in a shared location (e.g. under $HOME/gits-shared) and return the path to the checkout.
# It is designed to be used in other scripts to share git checkouts across different scripts and avoid multiple checkouts of the same repository.
# It also supports refreshing the checkout and clearing it if it is invalid.
# Usage: git-shared-checkout [--refresh|--clear] [--quiet] <repo_path> [--ref=<ref>]   | --version
#    eg: cat "$(git-shared-checkout https://github.com/Mac-H/ukko_gists)/readme.md"
#
# It needs to be possible to run without any other libraries (e.g. in a fresh docker image) and it should not produce any output on stdout except the path to the checkout (and error messages on stderr if needed).
#
GIT_SHARED_CHECKOUT_VERSION="0.0.5"
[[ -z "${HOME:-}" ]] && SHARED_GIT_DIR="/usr/share/gits-shared"
[[ -n "${HOME:-}" ]] && SHARED_GIT_DIR="${HOME}/gits-shared"

function help()
{
    {
        echo -e "Usage: $(basename "$THIS_EXE") [--refresh|--clear] [--quiet] <repo_path> [--ref=<ref>] | --version"
        echo -e "       <ref> = hash:###      -or-"
        echo -e "               branch:###    -or-"
        echo -e "               tag:###       -or-"
        echo -e "               hash-only:###  (No git history - only download the files)"
        echo -e "   eg: ${BOLD_BLUE_STDERR:-}cat \"\$($(basename "$THIS_EXE") https://github.com/Mac-H/ukko_gists)/readme.md\"${NC_STDERR:-}" >&2
    } >&2
}
function main()
{
    local option_is_refresh='no'
    local option_is_erase='no'
    local option_is_quiet='no'

    [[ "${GIT_SHARED_CHECKOUT_QUIET:-}" == "yes" ]] && option_is_quiet='yes'

    if [[ "${1:-}" == '--version' ]]; then
        echo "$(basename "$THIS_EXE") version $GIT_SHARED_CHECKOUT_VERSION"
        exit 0
    elif [[ "${1:---help}" == '--help' ]] ; then
        help
        exit 0
    fi

    #

    if [[ "${1:-}" == '--refresh' ]]; then
        option_is_refresh='yes'
        shift
    elif [[ "${1:-}" == '--clear' ]]; then
        option_is_erase='yes'
        shift
    fi

    if [[ "${1:-}" == '--quiet' ]] || [[ "${1:-}" == '--quiet=yes' ]] ; then
        option_is_quiet='yes'
        shift
    elif [[ "${1:-}" == '--quiet=no' ]] ; then
        option_is_quiet='no'
        shift
    fi

    local repo_path="${1:-}"
    local ref="${2:-}"

    local ref_type=''
    local ref_value=''
    if [[ "$ref" == --hash=* ]]; then
        ref_type='hash'
        ref_value="${ref#--hash=}"
    elif [[ "$ref" == --hash=* ]]; then
        ref_type='hash-only'
        ref_value="${ref#--hash=}"
    elif [[ "$ref" == '--ref=#'* ]]; then
        ref_type='hash'
        ref_value="${ref#--ref=#}"
        echo "⚠️  Deprecated used of --ref=#${ref_value} :  Use --ref=hash:${ref_value} instead" >&2
    elif [[ "$ref" == '--ref=branch:'* ]]; then
        ref_type='branch'
        ref_value="${ref#--ref=branch:}"
    elif [[ "$ref" == '--ref=tag:'* ]]; then
        ref_type='tag'
        ref_value="${ref#--ref=tag:}"
    elif [[ "$ref" == --ref=* ]]; then
        echo "⚠️  Invalid use of ${ref} : Expected --ref=branch:xxx, --ref=tag:xxx , --ref=hash:xxx, --ref=hash-only:xxx" >&2
        repo_path='' # Force show help and exit with error
    elif [[ -n "$ref" ]]; then
        echo "⚠️  Deprecated used of ${ref} :  Use --ref=branch:${ref} instead" >&2
        ref_type='branch'
        ref_value="$ref"
    fi

    if [[ -z "$repo_path" ]] || [[ "$repo_path" == '--'* ]]; then
        help
        exit 1
    fi

    repo_shorter="${repo_path%.git}"

    repo_shorter="${repo_path%.git}"
    if [[ "$repo_shorter" == "https://"* ]] ; then
        repo_shorter="${repo_shorter##https://}"
    elif [[ "$repo_shorter" == "git@"*     ]] ; then
        repo_shorter="${repo_shorter##git@}"
    fi

    full_dir="${SHARED_GIT_DIR%/}/${repo_shorter/://}"
    if [[ -n "$ref_type" ]] && [[ -n "$ref_value" ]]; then
        full_dir="${full_dir}_ref_${ref_type}_${ref_value}"
    fi

    _suffix=''
    [[ -n "$ref_type" ]] && _suffix=" [$ref_type:$ref_value]"
    local repo_caption="${repo_shorter}${_suffix}"

    #########################
    #
    local description="<EMPTY>"
    if [[ -d "$full_dir" ]] ; then
        if [[ "$option_is_refresh" == "yes" ]] || [[ "$option_is_erase" == "yes" ]] ; then
            do_with_check  rm -rf "$full_dir" && description="<ERASED>"
            description="<ERASED>"
        else
            description="$(git -C "$full_dir" describe --always --dirty 2>/dev/null)" || description="<INVALID_GIT>"
        fi
    fi
    echo "$full_dir"
    if [[ "$option_is_erase" == "yes" ]]; then
        echo -e "$repo_caption: ${BOLD_BLUE_STDERR:-}$description:${NC_STDERR:-} ℹ️  ERASED" >&2
        return 0
    elif [[ "$description" == "<INVALID_GIT>" ]]; then
        echo -e "$repo_caption: ${BOLD_RED_STDERR:-}$description:${NC_STDERR:-} -- Clearing" >&2
        do_with_check rm -rf "$full_dir"
    fi
    #####################
    #
    # Get it
    #

    if [ ! -d "$full_dir" ]; then
        mkdir -p "$full_dir"
        cd "$full_dir"
        if [[ "$ref_type" == '' ]] ; then
             do_with_check git clone  "$repo_path" "$full_dir"
        elif [[ "$ref_type" == 'branch' ]] ; then
             do_with_check git clone --branch "$ref_value" --depth 1 "$repo_path" "$full_dir"
        elif [[ "$ref_type" == 'hash' ]] ; then
             do_with_check git clone  "$repo_path" "$full_dir"
             do_with_check git -C "$full_dir" checkout -q "$ref_value"
        elif [[ "$ref_type" == 'hash-only' ]] ; then
             url="https://${repo_path/:/}/archive/${ref_value}.zip"
             do_with_check wget -L -O "/tmp/${ref_value}.zip" "$url"
             do_with_check unzip "/tmp/${ref_value}.zip" -d "${full_dir}"
        elif [[ "$ref_type" == 'tag' ]] ; then
             do_with_check git clone --branch "$ref_value"  --depth 1 "$repo_path" "$full_dir"
        else
            echo "⚠️  Invalid ref type '$ref_type' for ref '$ref_value'" >&2
            exit 1
        fi

        if [[ "$ref_type" != 'hash-only' ]] ; then

            [[ -f "${full_dir%/}/.gitmodules" ]] && do_with_check git submodule update --init --recursive

            if [[ -f "${full_dir%/}/.pre-commit-config.yaml" ]]; then
                if ! command -v pre-commit >/dev/null 2>&1 ; then
                    echo -e "⚠️  pre-commit not found in PATH.  Skipping pre-commit install for $repo_caption" >&2
                else
                    pushd "$full_dir" &>/dev/null
                    do_with_check pre-commit install >&2 # --install-hooks
                    echo "⚡ pre-commit hooks installed for $repo_caption" >&2
                    popd &>/dev/null
                fi
            fi
            description="$(git -C "$full_dir" describe --always --dirty)" || description="<INVALID>"
        else
            description="hash-only:${ref_value}"
        fi
    fi

    local suffix=''
    [[ "$description" == *'-dirty' ]] && suffix="${BOLD_RED_STDERR}  ⚠️  There are local changes${NC_STDERR}"
    if [[ "$option_is_quiet" == "no" ]] || [[ -n "$suffix" ]]; then
        echo -e "Using: ${BOLD_BLUE_STDERR:-}$repo_caption [$description]${NC_STDERR:-}$suffix" >&2
        echo -e "       └── $full_dir" >&2
    fi
    exit 0
}
function do_with_check()
{
    local caption="$*"

    local caption_decorated="$*"
    if [[ "$1" == '--caption='* ]]; then
        caption="${1#--caption=}"
        shift
    else
        caption_decorated="${BOLD_BLUE_STDERR:-}$caption${NC_STDERR:-}"
    fi
    local status=0
    local suffix=''

    echo -e "Running : ${caption_decorated}" >&2
    "$@" || status=$?
    if [[ "$status" == 0 ]] ; then
        true #echo -e "          -- OK" >&2
    else
        [[ "$status" == 1 ]] || suffix=" with status $status"
        echo -e "Ran    :${BOLD_RED_STDERR:-}$caption${NC_STDERR:-} -- Failed$suffix" >&2
        [[ "$caption" == "$*" ]] || echo -e "Command: ${BOLD_BLUE_STDERR:-}$*${NC_STDERR:-}" >&2
        exit 1
    fi
}

function do_install_directly()
{
    local INSTALL_DIR="${HOME%/}/.local/bin" ; [[ "$EUID" -eq 0 ]] && INSTALL_DIR="/usr/local/bin"
    local exe_path="${INSTALL_DIR%/}/$EXE_NAME"
    if [[ "$exe_path" == "$THIS_EXE" ]]; then
        echo "✅  This is already currently installed to $exe_path"
        return 0
    fi
    if ! cp "$THIS_EXE" "$exe_path"; then
        echo "❌  Failed to copy $THIS_EXE to $exe_path"
        return 1
    fi

    if ! [[ ":$PATH:" == *":$INSTALL_DIR:"* ]]; then
        echo "⚠️  '$EXE_NAME' installed to ${INSTALL_DIR@Q} but it is NOT in PATH.  Please add ${INSTALL_DIR@Q} to your PATH environment variable." >&2
        return 1
    fi
     echo "✅  '$EXE_NAME' installed successfully to ${INSTALL_DIR@Q} and is available in PATH"
}

THIS_EXE="$(readlink -m "${BASH_SOURCE[0]}")"
EXE_NAME="$(basename "$THIS_EXE")"


[[ -t 2 ]] &&  BOLD_BLUE_STDERR="\033[1;34m" && BOLD_RED_STDERR='\033[1;31m' &&  NC_STDERR='\033[0m' # Color codes for terminal output

if [[ "${1:-}" == '--install' ]]; then
    do_install_directly
else
    main "$@"
fi
