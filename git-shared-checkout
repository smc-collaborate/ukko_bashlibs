#!/bin/bash -u

#
# This is a utility to checkout git repositories in a shared location (e.g. under $HOME/gits-shared) and return the path to the checkout.
# It is designed to be used in other scripts to share git checkouts across different scripts and avoid multiple checkouts of the same repository.
# It also supports reloading the checkout and clearing it if it is invalid.
# Usage: git-shared-checkout [--reload|--clear] [--quiet] <repo_path> [--ref=<ref>]   | --version
#    eg: cat "$(git-shared-checkout https://github.com/Mac-H/ukko_gists)/readme.md"
#
# It needs to be possible to run without any other libraries (e.g. in a fresh docker image) and it should not produce any output on stdout except the path to the checkout (and error messages on stderr if needed).
#



if [[ -z "${HOME:-}" ]] ; then
    SHARED_GIT_DIR="/usr/share/gits-shared"
    SHARED_GIT_DIR_DISPLAY="/usr/share/gits-shared"
else
    SHARED_GIT_DIR="${HOME}/gits-shared"
     # shellcheck disable=SC2088
    SHARED_GIT_DIR_DISPLAY='~/gits-shared'
fi

APP_VERSION="v0.0.5d"

function app_help()
{
    #echo -e "$EXE_NAME: $APP_DESCRIPTION"
    echo -e "$EXE_NAME: Checkout a git repository to the shared location ${COLOR_BOLD_BLUE:-}${SHARED_GIT_DIR_DISPLAY}${COLOR_OFF:-} and return the path to the checkout."

    echo -e "Usage: $EXE_NAME [--reload|--clear] [--quiet] <repo_path> [--ref=<ref>]"
    echo -e "       <ref> = hash:###      -or-"
    echo -e "               branch:###    -or-"
    echo -e "               tag:###       -or-"
    echo -e "               hash-only:###  (No git history - only download the files)"
    echo -e "   eg: ${COLOR_BOLD_BLUE:-}cat \"\$($EXE_NAME https://github.com/Mac-H/ukko_gists)/readme.md\"${COLOR_OFF:-}"
    echo -e ""
    echo -e " -or-  $EXE_NAME [--list]"
}


####################################
# Custom load of parameters:
#
#    Value                 Default
#    --------------------  ----------------
#  * option_is_reload      'no'
#  * option_is_erase       'no'
#  * option_is_quiet       'no-unless-info'
#  * option_ref_type       ''
#  * option_ref_value      ''
#  * option_repo_url       ''
#
# This is called from load_params and should not be called directly.
#
#  * app_load_param 'all-defaults'       - Load all default values for options
#  * app_load_param 'option-arg' <arg>   - Load an option from an argument (e.g. --reload, --ref=branch:main)
#  * app_load_param 'direct-arg' <arg>   - Load a direct argument (e.g. the repo URL)
#
function app_load_param()
{
    local kind="$1"
    local arg="${2:-}"

    if [[ "$kind" == 'all-defaults' ]]; then
        option_is_reload='no'
        option_is_erase='no'
        option_is_quiet='no-unless-info'

        option_ref_type=''
        option_ref_value=''
        option_repo_url=''
        option_list_shared_checkouts='no'

        [[ "${GIT_SHARED_CHECKOUT_QUIET:-}" == "yes" ]] && option_is_quiet='yes'
    elif [[ "$kind" == 'direct-arg' ]]; then
        #
        # Direct arguments  (Typically not starting with - or --.  However if '--' is provided, then all subsequent arguments are treated as direct arguments even if they start with - or --)
        #
        if [[ "$arg" == 'branch:'* ]]; then
            option_ref_type='branch'
            option_ref_value="${arg#branch:}"
            giveWarning "Deprecated used of ${arg} :  Use --ref=${arg} instead"
        elif [[ -z "$option_repo_url" ]]; then
            option_repo_url="$arg"
        else
            help_with_exit "Multiple repository URLs provided.  Already have ${option_repo_url@Q} but adding '${arg@Q}' is an error."

            return 1
        fi
    elif [[ "$kind" == 'option-arg' ]]; then
        #
        # Option arguments  (Typically of the form -n or --name)
        #
        if [[ "$arg" == '--list' ]] ; then
            option_list_shared_checkouts=yes
        elif [[ "$arg" == '--reload' ]]; then
            option_is_reload='yes'
        elif [[ "$arg" == '--clear' ]]; then
            option_is_erase='yes'
        elif [[ "$arg" == '--quiet' ]] || [[ "$arg" == '--quiet=yes' ]] ; then
            option_is_quiet='yes'
        elif [[ "$arg" == '--quiet=no' ]] ; then
            option_is_quiet='no'
        elif [[ "$arg" == '--ref='* ]]; then
            ref_arg="${arg#--ref=}"
            if [[ "$ref_arg" == '#'* ]]; then
                option_ref_type='hash'
                option_ref_value="${ref_arg#\#}"
                giveWarning "Deprecated used of --ref=#${option_ref_value} :  Use --ref=hash:${option_ref_value} instead"
            elif [[ -n "$ref_arg" ]]; then
                for x in hash hash-only branch tag ; do
                    if [[ "$ref_arg" == "$x:"* ]]; then
                        option_ref_type="$x"
                        option_ref_value="${ref_arg#"$x:"}"
                        break
                    fi
                done
                [[ -z "$option_ref_type" ]] && help_with_exit "Invalid format for ${arg@Q} : Expected --ref=branch:<branch_name> or --ref=tag:<tag_name> or --ref=hash:<hash_value> or --ref=hash-only:<hash_value>"
            fi
        else
            return 1
        fi
    else
        giveWarning "Invalid use:  app_load_param(${*@Q}) ignored"
    fi


    return 0
}


##############################################
#
# Load:
#
#    Value                 Default
#    --------------------  ----------------
#  * option_is_reload      'no'
#  * option_is_erase       'no'
#  * option_is_quiet       'no-unless-info'
#  * option_ref_type       ''
#  * option_ref_value      ''
#  * option_repo_url       ''


function app_run()
{

    if [[ "$option_list_shared_checkouts" == "yes" ]] ; then
        doListSharedCheckouts
        [[ -n "$option_repo_url" ]] || return 0
    fi

    [[ -n "$option_repo_url" ]] || do_exit_with_help "Repository URL not provided."



    ##############################################
    #
    # Load:
    #  * repo_friendlyName
    #  * repo_fullDir
    #
    repo_friendlyName="${option_repo_url%.git}"
    if [[ "$repo_friendlyName" == "https://"* ]] ; then
        repo_friendlyName="${repo_friendlyName##https://}"
    elif [[ "$repo_friendlyName" == "git@"*     ]] ; then
        repo_friendlyName="${repo_friendlyName##git@}"
    fi

    repo_fullDir="${SHARED_GIT_DIR%/}/${repo_friendlyName/://}"
    if [[ -n "$option_ref_type" ]] ; then
        repo_fullDir="${repo_fullDir%/}/${option_ref_type}_${option_ref_value}"
    else
        repo_fullDir="${repo_fullDir%/}/default_branch"
    fi

    [[ -n "$option_ref_type" ]] && repo_friendlyName+=" [$option_ref_type:$option_ref_value]"

    #########################
    #
    # Load:
    # * gitInfo_description
    # * gitInfo_warning
    #
    gitInfo_description=""
    gitInfo_warning=''
    if [[ ! -d "$repo_fullDir" ]] ; then
        gitInfo_description="EMPTY"
    elif [[ "$option_is_reload" == "yes" ]] || [[ "$option_is_erase" == "yes" ]] ; then
        do_with_check  rm -rf "$repo_fullDir"
        gitInfo_description="ERASED"
    else
        load_gitInfo
    fi

    if true ; then
    {
        echo "ℹ️  !! ${THIS_EXE} $*"
        echo "ℹ️  !! -----------------------------------------------------"
        echo "ℹ️  !! * repo_friendlyName   = $repo_friendlyName"
        echo "ℹ️  !! * repo_fullDir        = $repo_fullDir"
        echo "ℹ️  !! "
        echo "ℹ️  !! * option_repo_url     = $option_repo_url"
        echo "ℹ️  !! * option_ref_type     = $option_ref_type"
        echo "ℹ️  !! * option_ref_value    = $option_ref_value"
        echo "ℹ️  !! "
        echo "ℹ️  !! * gitInfo_description = $gitInfo_description"
        echo "ℹ️  !! * gitInfo_warning     = $gitInfo_warning"
        echo "ℹ️  !! -----------------------------------------------------"
    } >&2
    fi

    #########################
    #
    # Clear if needed
    #
    if [[ "$option_is_erase" == "yes" ]]; then
        echo -e "$repo_friendlyName: ${BOLD_BLUE_STDERR:-}ℹ️  $gitInfo_description${NC_STDERR:-} " >&2
        return 0
    fi

    if [[ "$gitInfo_warning" == "<INVALID_GIT>" ]]; then
        giveAlert "$repo_friendlyName: $gitInfo_description -- Clearing"
        do_with_check rm -rf "$repo_fullDir"
    fi

    #########################
    #
    #
    #

    if [[ ! -d "$repo_fullDir" ]]; then

        mkdir -p "$repo_fullDir"
        cd "$repo_fullDir" || true

        [[ "$option_is_quiet" == 'no-unless-info' ]] && echo -e "Loading from cloud: ${BOLD_BLUE_STDERR:-}$repo_friendlyName${NC_STDERR:-} into $repo_fullDir" >&2 && option_is_quiet='no'

        #########################
        #
        # Load the repo into $repo_fullDir
        #
        # Update:
        #  * gitInfo_description
        #  * gitInfo_warning
        #

        if [[ "$option_ref_type" == '' ]] ; then
             do_with_check git clone  "$option_repo_url" "$repo_fullDir"
        elif [[ "$option_ref_type" == 'branch' ]] ; then
             do_with_check git clone --branch "$option_ref_value" --depth 1 "$option_repo_url" "$repo_fullDir"
        elif [[ "$option_ref_type" == 'hash' ]] ; then
             do_with_check git clone  "$option_repo_url" "$repo_fullDir"
             do_with_check git -C "$repo_fullDir" checkout -q "$option_ref_value"
        elif [[ "$option_ref_type" == 'hash-only' ]] ; then
             url="https://${option_repo_url/:/}/archive/${option_ref_value}.zip"
             do_with_check wget -L -O "/tmp/${option_ref_value}.zip" "$url"
             do_with_check unzip "/tmp/${option_ref_value}.zip" -d "${repo_fullDir}"
        elif [[ "$option_ref_type" == 'tag' ]] ; then
             do_with_check git clone --branch "$option_ref_value"  --depth 1 "$option_repo_url" "$repo_fullDir"
        else
            giveAlert "Invalid ref type '$option_ref_type' for ref '$option_ref_value'"
            exit 1
        fi

        if [[ "$option_ref_type" != 'hash-only' ]] ; then

            [[ -f "${repo_fullDir%/}/.gitmodules" ]] && do_with_check git submodule update --init --recursive

            if [[ -f "${repo_fullDir%/}/.pre-commit-config.yaml" ]]; then
                if ! command -v pre-commit >/dev/null 2>&1 ; then
                    giveAlert "pre-commit not found in PATH.  Skipping pre-commit install for $repo_friendlyName"
                elif ! pushd "$repo_fullDir" &>/dev/null ; then
                    giveAlert "Unable to enter directory $repo_fullDir to install pre-commit hooks.  Skipping pre-commit install for $repo_friendlyName"
                else
                    do_with_check pre-commit install >&2 # --install-hooks
                    echo "⚡ pre-commit hooks installed for $repo_friendlyName" >&2
                    popd &>/dev/null || true
                fi
            fi
        fi
        load_gitInfo
    fi

    #################################################################################################################################
    # Summarise based on:
    #   * repo_friendlyName
    #   * gitInfo_description
    #   * gitInfo_warning
    #   * repo_fullDir
    #
    local repo_caption="$repo_friendlyName"
    local repo_displayDir="${repo_fullDir}"
    if [[ -n "${HOME:-}" ]] && [[ "$repo_displayDir" == "${HOME%/}/"* ]]; then
        # shellcheck disable=SC2088
        repo_displayDir="~/${repo_displayDir#"${HOME%/}/"}"
    fi
    [[ -n $gitInfo_description ]] &&  repo_caption+=" $gitInfo_description"
    [[ -n "$gitInfo_warning"   ]] &&  gitInfo_warning=" ${COLOUR[BOLD_RED_STDERR]:-}⚠️  $gitInfo_warning${COLOUR[OFF_STDERR]:-}"

    if [[ "$option_is_quiet" != "yes" ]] || [[ -n "$gitInfo_warning" ]] || [[ "$hadWarning" == "yes" ]]; then
        echo -e "Using: ${COLOUR[BOLD_BLUE_STDERR]:-}${repo_caption}${COLOUR[OFF_STDERR]:-}$gitInfo_warning" >&2
        echo -e "       └── $repo_displayDir" >&2
    fi
    echo "$repo_fullDir"
    exit 0
}



##############################################################################################################################################
#
# Utils for this code
#

function getDirs()
{
    local baseDir="$1"
    find "$baseDir" -mindepth 1 -maxdepth 1 -type d | sed --unbuffered "s|^${baseDir%/}/||g"
}

function padRight()
{
    local width="$1"
    local text="$2"

    printf "%-${width}s" "$text"
}

function dump_gitInfoOnDir()
{
    local _dir="$1"

    repo_fullDir="$_dir"

    y="${repo_fullDir#"$SHARED_GIT_DIR/"}"

    repo_friendlyName="${y%/*}"
    repo_friendlyName="${repo_friendlyName/\//:}"
    _dispDir="${SHARED_GIT_DIR_DISPLAY%/}/$y"
    _checkoutDirPart="${y##*/}"
    _repoDirPart="${y%/*}"

    if [[ "$_checkoutDirPart" == "default_branch" ]]; then
        option_ref_type=""
        option_ref_value=""
        _checkoutKindValue=""
    else
        option_ref_type="${_checkoutDirPart%%_*}"
        option_ref_value="${_checkoutDirPart#*_}"
        _checkoutKindValue="$option_ref_type:$option_ref_value"
    fi

    # Load:
    # * gitInfo_description
    # * gitInfo_warning
    load_gitInfo 'yes'

    ##########
    # SUmmarise

    local repo_caption="$repo_friendlyName"
    [[ -n $gitInfo_description ]] &&  repo_caption+=" $gitInfo_description"
    local _dirAsPrinted="$_dispDir"

    [[ -z "$gitInfo_warning"   ]] || gitInfo_warning=" ${COLOUR[BOLD_RED_STDERR]:-}⚠️  $gitInfo_warning${COLOUR[OFF_STDERR]:-}"
    _checkoutDirPart="${y##*/}"
    _repoDirPart="${y%/*}"
    echo -en  " •  ${SHARED_GIT_DIR_DISPLAY%/}/${COLOUR[BOLD_BLUE_STDOUT]:-}${_repoDirPart}${COLOUR[OFF_STDOUT]:-}/${_checkoutDirPart} "

    _maxLen=80
    _a="${#_repoDirPart}"
    _b="${#_checkoutDirPart}"

    printf "%-*s" "$((_maxLen - _a - _b - 3))" ""
    echo -e "${COLOUR[BOLD_BLUE_STDOUT]:-}${gitInfo_description}${COLOUR[OFF_STDOUT]:-}$gitInfo_warning"


}
function doListSharedCheckouts()
{

    readarray -t _dirs < <(find "$SHARED_GIT_DIR" -mindepth 4 -maxdepth 4 -type d)

    for _dir in "${_dirs[@]}"; do
        dump_gitInfoOnDir "$_dir"
    done

}



##############################################
#
# Evalues git stored in:
#  * repo_fullDir
#
# Loads:
#  * gitInfo_description
#  * gitInfo_warning
#
# Also evaluates and triggers warnings based on:
#  * option_ref_type
#  * option_ref_value
#
gitInfo_description=''
gitInfo_warning=''
function load_gitInfo()
{
    local hash=''
    local branch=''

    local alwaysGiveBranch="${1:-no}"
    gitInfo_description=''
    gitInfo_warning=''

    if [[ ! -d "$repo_fullDir" ]] ; then
        gitInfo_warning="MISSING"
        return
    elif [[ "$option_ref_type" == 'hash-only' ]] ; then
        gitInfo_description="only:#${option_ref_value}"
    elif ! hash="$(git -C "$repo_fullDir" describe --always --dirty 2>/dev/null)"; then
        gitInfo_warning="<INVALID_GIT>"
    else
        branch="$(git -C "$repo_fullDir" branch --show-current 2>/dev/null || true)"
        gitInfo_description="${branch}@${hash}"

        if [[ "$option_ref_type" == "hash" ]] && [[ "${hash%-dirty}" != "$option_ref_value" ]]; then
            gitInfo_warning="Hash is not the expected value: #$option_ref_value"
        elif [[ "$option_ref_type" == "branch" ]] && [[ "$branch" != "$option_ref_value" ]]; then
            gitInfo_warning="Branch is not the expected value: ${option_ref_value:-}"
        else
            if [[ "$option_ref_type" == "hash" ]] ; then
            if [[ "${hash}" == *-dirty ]]; then
                gitInfo_description="🔓  "
            else
                gitInfo_description="🔒  "
            fi
            elif [[ "$option_ref_type" == "branch" ]] ; then
                if [[ "$alwaysGiveBranch" == "yes" ]] ; then
                    gitInfo_description="🔓  ${gitInfo_description}"
                else
                    gitInfo_description="🔓  @${hash}"
                fi
            elif [[ "$option_ref_type" == "tag" ]] ; then
                gitInfo_description+="🔓  "
            elif [[ -z "$option_ref_type" ]] ; then
                gitInfo_description="🔓  ${gitInfo_description}"
            else
                gitInfo_description+="🔓  "
            fi
        fi
        [[ "$hash" != *-dirty ]] || gitInfo_warning="There are local changes"
    fi
}


##############################################################################################################################################
#
# Standard from here on - not specific to git-shared-checkout
#
# This is a standard template for bash scripts that uses:
#  * APP_VERSION     | Optional but recommended
#  * APP_DESCRIPTION | Optional
#
#  * app_help        | Optional but recommended
#  * app_load_param  | Optional but recommended
#  * app_run         | Required
#
# It makes available:
#
#    $EXE_NAME
#    $THIS_EXE
#    do_exit_with_help  "<optional error message>"
#    do_with_check <command...>  - Run a command and exit with an error message if it fails
#    giveWarning "<warning message>" - Give a warning message that will be shown at the end of processing (if any)
#
#  Colours:
#    BOLD_BLUE_STDERR, BOLD_RED_STDERR, NC_STDERR - For colored output to stderr (e.g. for warnings and info)
#    BOLD_BLUE_STDOUT, BOLD_RED_STDOUT, NC_STDOUT - For colored output to stdout (if needed)
#    BOLD_BLUE       , BOLD_RED       , NC        - As standard
#
#  These will not be blanked out if redirecting (or --no-colours) passed
#

function giveCodeHelp()
{
    # this is dumped with the hidden option '--code-help'


    echo " This is a standard template for bash scripts that uses:"
    echo "  * APP_VERSION     | Optional but recommended"
    echo "  * APP_DESCRIPTION | Optional"
    echo ""
    echo "  * app_help        | Optional but recommended"
    echo "  * app_load_param  | Optional but recommended"
    echo "  * app_run         | Required"
    echo ""
    echo " It makes available:"
    echo ""
    echo "    \$EXE_NAME"
    echo "    \$THIS_EXE"
    echo "    do_exit_with_help  '<optional error message>'"
    echo "    do_with_check <command...>  - Run a command and exit with an error message if it fails"
    echo "    giveWarning '<warning message>' - Give a warning message that will be shown at the end of processing (if any)"
    echo "   "

    coloursShow
}

function do_exit_with_help()
{
    local fatal_error_message="${1:-}"

    COLOR_BOLD_BLUE=${COLOR_BOLD_BLUE_STDERR:-}
    COLOR_OFF=${COLOR_OFF_STDERR:-}
    EXE_NAME="$(basename "$THIS_EXE")"
    {
        [[ -n "$fatal_error_message" ]] && echo -e "${COLOR_BOLD_RED_STDERR:-}❌  $fatal_error_message${COLOR_OFF_STDERR:-}"

        [[ -n "${APP_DESCRIPTION:-}" ]] && echo -e "$EXE_NAME: $APP_DESCRIPTION"
        if declare -F app_help >/dev/null 2>&1 ; then
            app_help
            echo ""
            echo -e "Additional functions:"
        else

            echo -e "Usage: $EXE_NAME <parameters>"
            echo -e ""
            echo -e "Parameters:"
        fi
        echo -e "     --help     : Give this help message"
        [[ -n "${APP_VERSION:-}" ]] && echo -e "     --version  : Give version : $APP_VERSION"

        if [[ "$INSTALLATION_NOTE" == "OK" ]] ; then
            echo -e "     --uninstall: Uninstalls from $INSTALL_DIR"
        else
            echo -e "     --install  : Installs to $INSTALL_DIR"
        fi
        echo -e "     --colours=no|yes|auto  (Default 'auto')"
    } >&2

    if [[ -n "$fatal_error_message" ]]; then
        exit 1
    else
        exit 0
    fi
}


function load_params()
{
    local am_processing_options='yes'

    function _app_get_params()
    {
        declare -F app_load_param  &> /dev/null  || return 0
        app_load_param "$@"
    }

    _app_get_params 'all-defaults'
    local giveCodeHelp='no'
    for arg in "$@"; do
        [[ -z "$arg" ]] && continue
        if [[ "$am_processing_options" == "yes" ]] && [[ "$arg" == '-'* ]]; then
            if [[ "$arg" == '--' ]] ; then
                am_processing_options='no'
            elif [[ "$arg" == '--version' ]] && [[ -n "${APP_VERSION:-}" ]]; then
                echo "$(basename "$THIS_EXE") $APP_VERSION"
                exit 0
            elif [[ "$arg" == '--help' ]]; then
                do_exit_with_help
            elif [[ "$arg" == '--colours=no' ]] || [[ "$arg" == '--colours=yes' ]] || [[ "$arg" == '--colours=auto' ]]; then
                colours_load "${arg#--colours=}"
            elif [[ "$INSTALLATION_NOTE" == "OK" ]] && [[ "$arg" == "--uninstall" ]] ; then
                (sleep 0.5 && rm -f "$THIS_EXE" && echo "Removed $THIS_EXE") &
                exit 0
            elif [[ "$INSTALLATION_NOTE" != "OK" ]] && [[ "$arg" == "--install" ]] ; then
                do_install_directly
                exit 0
            elif [[ "$arg" == '--code-help' ]] ; then
                giveCodeHelp='yes'
            elif ! _app_get_params 'option-arg' "$arg"; then
                help_with_exit "Unknown option ${arg@Q}"
            fi
        else
            _app_get_params 'direct-arg' "$arg" || help_with_exit "Unknown argument ${arg@Q}"
        fi
    done

    if [[ "$giveCodeHelp" == "yes" ]]; then
        giveCodeHelp
        exit 0
    fi

}

function do_with_check()
{
    local caption="$*"

    local caption_decorated="$*"
    if [[ "$1" == '--caption='* ]]; then
        caption="${1#--caption=}"
        shift
    else
        caption_decorated="${COLOR_BOLD_BLUE_STDERR:-}$caption${COLOR_OFF_STDERR:-}"
    fi
    local status=0
    local suffix=''

    echo -e "Running : ${caption_decorated}" >&2
    "$@" || status=$?
    if [[ "$status" == 0 ]] ; then
        true #echo -e "          -- OK" >&2
    else
        [[ "$status" == 1 ]] || suffix=" with status $status"
        echo -e "Ran    :${COLOR_BOLD_RED_STDERR:-}$caption${COLOR_OFF_STDERR:-} -- Failed$suffix" >&2
        [[ "$caption" == "$*" ]] || echo -e "Command: ${COLOR_BOLD_BLUE_STDERR:-}$*${COLOR_OFF_STDERR:-}" >&2
        exit 1
    fi
}



function do_install_directly()
{
    local INSTALL_DIR="${HOME%/}/.local/bin" ; [[ "$EUID" -eq 0 ]] && INSTALL_DIR="/usr/local/bin"
    if [[ "$INSTALLATION_NOTE" == "OK" ]]; then
        echo "✅ $app_name_and_version is already successfully installed to  ${INSTALL_DIR@Q}"
        return 0
    fi

    if [[ "$INSTALLATION_NOTE" == *"[NotCopied]"* ]] && ! cp "$THIS_EXE" "$INSTALL_DIR_WITH_EXE" ; then
        echo "❌  Failed to copy $THIS_EXE to $INSTALL_DIR_WITH_EXE"
        return 1
    fi

    if [[ "$INSTALLATION_NOTE" == *"[DirNotInPath]"* ]] ; then
        echo "⚠️  $app_name_and_version installed to ${INSTALL_DIR@Q} but it is NOT in PATH. Please add ${INSTALL_DIR@Q} to your PATH environment variable." >&2
        return 1
    fi
     echo "✅  $app_name_and_version installed successfully to ${INSTALL_DIR@Q} and is available in PATH"
}


hadWarning='no'
function giveWarning()
{
    hadWarning='yes'
    [[ -n "$*" ]] && echo -e "${BOLD_RED_STDERR:-}⚠️  $*${NC_STDERR:-}" >&2
}


THIS_EXE="$(readlink -m "${BASH_SOURCE[0]}")"
EXE_NAME="$(basename "$THIS_EXE")"
app_name_and_version="${EXE_NAME}"
[[ "${APP_VERSION:-}" ]] && app_name_and_version+=" ($APP_VERSION)"

INSTALL_DIR="${HOME%/}/.local/bin" ; [[ "$EUID" -eq 0 ]] && INSTALL_DIR="/usr/local/bin"
INSTALL_DIR_WITH_EXE="${INSTALL_DIR%/}/$EXE_NAME"
INSTALLATION_NOTE=''
if [[ "$INSTALL_DIR_WITH_EXE" != "$THIS_EXE" ]]; then
    INSTALLATION_NOTE+='[NotCopied]'
elif ! [[ ":$PATH:" == *":$INSTALL_DIR:"* ]]; then
    INSTALLATION_NOTE+='[DirNotInPath]'
else
    INSTALLATION_NOTE+='OK'
fi


declare -A COLOUR=()
declare -A COLOUR_CODES=(
        [BOLD_BLUE]="\033[1;34m"
        [BOLD_RED]='\033[1;31m'
        [OFF]='\033[0m'
    )

function colours_load()
{
    local arg="${1:-auto}"  # yes|no|auto

    local kind
    local colourName
    local colourCode

    for kind in "_STDOUT" "_STDERR" ""; do

        if [[ "$arg" == 'yes' ]] ; then
            _colour=yes
        elif [[ "$arg" == 'no' ]] ; then
            _colour=no
        else
            _colour=yes
            [[ "$kind" == "_STDOUT" ]] && ! [[ -t 1 ]] && _colour=no
            [[ "$kind" == "_STDERR" ]] && ! [[ -t 2 ]] && _colour=no
        fi

        if [[ "$_colour" == 'yes' ]]; then

            for colourName in "${!COLOUR_CODES[@]}"; do
                local colourCode="${COLOUR_CODES[$colourName]}"

                local codeName="${colourName}"
                [[ -n "$kind" ]] && codeName+="$kind"

                COLOUR["${codeName}"]="$colourCode"
            done
        fi
    done

}

function coloursShow()
{

        echo '╭─────────────────────────────────────────────────────────'
        {
            echo "Colour support is available in the script:"
            echo "  eg: echo -e \"This is \${COLOUR[BOLD_BLUE_STDOUT]:-}blue\${COLOUR[OFF_STDOUT]:-}\""
            echo "      echo -e \"This is \${COLOUR[BOLD_BLUE_STDERR]:-}blue\${COLOUR[OFF_STDERR]:-}\" >&2"
            echo ""
            echo "Redirection of stdout and stderr will automatically disable colours for that stream (e.g. \"echo test > out.txt\" or \"echo test 2> err.txt\")"
            echo "You can also force enable or disable colours with the --colours option (e.g. \"--colours=yes\" or \"--colours=no\")"
            echo
            echo 'The colours available in the current configuration are:'
            for colourName in "${!COLOUR[@]}"; do
                if [[ "$colourName" != "OFF"* ]]; then
                    if [[ "$colourName" == *"_STDOUT" ]]; then
                        offCode="OFF_STDOUT"
                    elif [[ "$colourName" == *"_STDERR" ]]; then
                        offCode="OFF_STDERR"
                    else
                        offCode="OFF"
                    fi

                    printf ' • echo -e %-32s%-22s%-28s → ' "\"\${COLOUR[$colourName]:-}\"" "${colourName@Q}" "\"\${COLOUR[$offCode]:-}\""
                    echo -e "${COLOUR[$colourName]}$colourName${COLOUR[$offCode]:-}"

                fi
            done
            echo ""
            list=''
            for colourName in "${!COLOUR_CODES[@]}"; do
                if [[ "$colourName" != "OFF" ]] ; then
                [[ -z "$list" ]] || list+=","
                list+=" $colourName"
                fi
            done
            echo "The base colours are: ${list}"
            echo ""
        } | sed --unbuffered 's/^/│/g'
        echo '╰─────────────────────────────────────────────────────────'

}

colours_load 'auto'

